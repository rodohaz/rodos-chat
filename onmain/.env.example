# Example .env
PORT=3000
# Ollama base URL (default when running ollama locally is http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Ollama model name to use when spawning bot responses (example)
OLLAMA_MODEL=llama2
# If you want the server to allow bot creation set to "true"
ALLOW_BOTS=true
